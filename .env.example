QB_RULES_APP_ENV=development
QB_RULES_HOST=127.0.0.1
QB_RULES_PORT=8000
QB_RULES_DATABASE_URL=sqlite:///./data/qb_rules.db
QB_RULES_REQUEST_TIMEOUT=10
QB_RULES_QB_BASE_URL=http://127.0.0.1:8080
QB_RULES_QB_USERNAME=admin
QB_RULES_QB_PASSWORD=
QB_RULES_JACKETT_API_URL=
QB_RULES_JACKETT_QB_URL=
QB_RULES_JACKETT_API_KEY=
# Optional manual language assignments for Jackett indexers whose metadata is missing/wrong.
# Supports JSON or semicolon assignments, for example:
# QB_RULES_JACKETT_LANGUAGE_OVERRIDES={"noname-clubl":["ru"],"thepiratebay":["en"]}
# QB_RULES_JACKETT_LANGUAGE_OVERRIDES=noname-clubl=ru;thepiratebay=en,multi
QB_RULES_JACKETT_LANGUAGE_OVERRIDES=
QB_RULES_OMDB_API_KEY=
QB_RULES_WINDOWS_HOST_MOUNT_ROOT=/host

# Docker defaults:
# - C:\Users\nucc\docker-config\docker-compose.yml binds the container on 0.0.0.0
#   internally and publishes this port.
# - If qBittorrent or Jackett run on the host machine, use host.docker.internal URLs.
# QB_RULES_QB_BASE_URL=http://host.docker.internal:8080
# QB_RULES_JACKETT_API_URL=http://host.docker.internal:9117
# Windows file paths saved in settings (for example Stremio LevelDB or Jellyfin DB)
# are translated inside Docker under QB_RULES_WINDOWS_HOST_MOUNT_ROOT.
