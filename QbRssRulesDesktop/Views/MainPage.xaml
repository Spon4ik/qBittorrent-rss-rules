<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="QbRssRulesDesktop.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Content>
        <Grid RowDefinitions="Auto,*">
            <Border
                Padding="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
                    <StackPanel Spacing="2">
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="qB RSS Rules Desktop" />
                        <TextBlock
                            x:Name="ConnectionStatusText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Starting..." />
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        Click="OnStartBackendClicked"
                        Content="Start Backend"
                        MinWidth="132" />
                    <Button
                        Grid.Column="2"
                        Click="OnRetryClicked"
                        Content="Retry"
                        MinWidth="84" />
                    <Button
                        Grid.Column="3"
                        Click="OnOpenInBrowserClicked"
                        Content="Open In Browser"
                        MinWidth="140" />
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <WebView2 x:Name="AppWebView" NavigationCompleted="OnNavigationCompleted" />

                <Border
                    x:Name="OfflinePanel"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    Visibility="Collapsed">
                    <Grid>
                        <StackPanel
                            MaxWidth="680"
                            Padding="24"
                            Spacing="10"
                            VerticalAlignment="Center">
                            <TextBlock
                                FontSize="24"
                                FontWeight="SemiBold"
                                Text="Backend is not reachable" />
                            <TextBlock
                                x:Name="OfflineMessageText"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock Text="Manual fallback commands:" />
                            <StackPanel Spacing="2">
                                <TextBlock
                                    FontFamily="Consolas"
                                    Text="scripts\run_dev.bat api" />
                                <TextBlock
                                    FontFamily="Consolas"
                                    Text="scripts\run_dev.bat full" />
                            </StackPanel>
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="10">
                                <Button
                                    Click="OnStartBackendClicked"
                                    Content="Start Backend"
                                    MinWidth="132" />
                                <Button
                                    Click="OnRetryClicked"
                                    Content="Retry"
                                    MinWidth="120" />
                                <Button
                                    Click="OnOpenInBrowserClicked"
                                    Content="Open In Browser"
                                    MinWidth="140" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Page.Content>
</Page>
